PROJECT_NAME=ASR Test Platform
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DEFAULT_MODEL=whisper
MODEL_ROOT=./models
MODEL_REGISTRY_PATH=backend/config/model_registry.example.json
AUTO_LOAD_DEFAULT_MODEL=false
AUTO_LOAD_ON_REQUEST=true
TEMP_DIR=./backend/tmp
TARGET_SAMPLE_RATE=16000
TARGET_CHANNELS=1
NORMALIZED_AUDIO_SUFFIX=.wav
VAD_BACKEND=noop
VAD_MODEL_PATH=
VAD_DEVICE=cpu
VAD_ENERGY_THRESHOLD=1500
LOG_LEVEL=INFO
LOG_DIR=./backend/logs
LOG_FILE=app.log
